<%#
  Shared SVG bed renderer — micro-grid with plant regions.

  Required locals:
    bed       — Bed record (has grid_cols, grid_rows, canvas_color, polygon?, canvas_points_array)
    plants    — Array of Plant records (with grid_x/y/w/h, variety_name, crop_type, lifecycle_stage, quantity)
    max_height — String, e.g. "300px" or "400px" (default "300px")
    interactive — Boolean, if true adds @click for AI drawer on empty areas (default false)
%>
<%
  max_height ||= "300px"
  interactive ||= false
  cell = 10
  gcols = bed.grid_cols
  grows = bed.grid_rows
  canvas_color = (bed.respond_to?(:canvas_color) && bed.canvas_color) || '#e8e4df'
%>
<svg viewBox="0 0 <%= gcols * cell %> <%= grows * cell %>"
     style="width: 100%; max-height: <%= max_height %>; min-height: 80px;"
     preserveAspectRatio="xMidYMid meet"
     <% if interactive %>@click="openAIForBed('<%= bed.name %>', <%= gcols * grows - plants.sum { |p| (p.grid_w || 1) * (p.grid_h || 1) } %>)"<% end %>>

  <!-- Bed outline -->
  <% if bed.polygon? %>
    <%
      pts = bed.canvas_points_array
      xs = pts.map { |p| p[0] }; ys = pts.map { |p| p[1] }
      min_x = xs.min; min_y = ys.min
      svg_pts = pts.map { |p| "#{p[0] - min_x},#{p[1] - min_y}" }.join(" ")
    %>
    <polygon points="<%= svg_pts %>" fill="<%= canvas_color %>" fill-opacity="0.15" stroke="<%= canvas_color %>" stroke-width="1.5"/>
  <% else %>
    <rect x="0" y="0" width="<%= gcols * cell %>" height="<%= grows * cell %>" rx="6"
          fill="<%= canvas_color %>" fill-opacity="0.15" stroke="<%= canvas_color %>" stroke-width="1.5"/>
  <% end %>

  <!-- Grid lines -->
  <% (1...gcols).each do |i| %>
    <line x1="<%= i * cell %>" y1="0" x2="<%= i * cell %>" y2="<%= grows * cell %>" stroke="rgba(0,0,0,0.04)" stroke-width="0.3"/>
  <% end %>
  <% (1...grows).each do |i| %>
    <line x1="0" y1="<%= i * cell %>" x2="<%= gcols * cell %>" y2="<%= i * cell %>" stroke="rgba(0,0,0,0.04)" stroke-width="0.3"/>
  <% end %>

  <!-- Plant regions -->
  <% plants.each do |plant| %>
    <%
      px = (plant.grid_x || 0) * cell
      py = (plant.grid_y || 0) * cell
      pw = (plant.grid_w || 1) * cell
      ph = (plant.grid_h || 1) * cell
      pfill = case plant.crop_type.to_s.downcase
        when 'tomato', 'pepper', 'eggplant' then '#fecaca'
        when 'lettuce', 'spinach', 'chard', 'kale' then '#bbf7d0'
        when 'herb', 'basil' then '#a7f3d0'
        when 'flower' then '#fef08a'
        when 'cucumber', 'squash', 'melon', 'zucchini' then '#bae6fd'
        else '#e5e7eb'
      end
      show_text = pw >= 20 && ph >= 15
      font_name = [pw * 0.12, ph * 0.18, 8].min
      font_stage = [pw * 0.09, ph * 0.14, 6].min
    %>
    <a href="/plants/<%= plant.id %>" style="pointer-events: auto; cursor: pointer;" <% if interactive %>@click.stop<% end %>>
      <rect x="<%= px + 0.5 %>" y="<%= py + 0.5 %>" width="<%= pw - 1 %>" height="<%= ph - 1 %>"
            rx="3" fill="<%= pfill %>" stroke="#d1d5db" stroke-width="0.8" stroke-opacity="0.4"/>
      <% if show_text %>
        <text x="<%= px + pw/2 %>" y="<%= py + ph/2 - (plant.quantity && plant.quantity > 1 ? 1 : 2) %>"
              text-anchor="middle" dominant-baseline="central"
              font-size="<%= font_name %>" font-weight="600" fill="#1a2e05">
          <%= plant.variety_name.length > (pw / font_name * 1.2).to_i ? plant.variety_name[0..((pw / font_name * 1.0).to_i)] + '..' : plant.variety_name %>
        </text>
        <% if plant.quantity && plant.quantity > 1 %>
          <text x="<%= px + pw/2 %>" y="<%= py + ph/2 + font_name %>"
                text-anchor="middle" dominant-baseline="central"
                font-size="<%= font_stage %>" fill="#6b7280">x<%= plant.quantity %></text>
        <% else %>
          <text x="<%= px + pw/2 %>" y="<%= py + ph/2 + font_name %>"
                text-anchor="middle" dominant-baseline="central"
                font-size="<%= font_stage %>" fill="#6b7280"><%= plant.lifecycle_stage.tr('_', ' ') %></text>
        <% end %>
      <% end %>
    </a>
  <% end %>
</svg>

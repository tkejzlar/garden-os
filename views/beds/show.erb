<a href="/garden" style="color: var(--green-900); font-size: 13px; text-decoration: none;">← Back to garden</a>

<h2 style="margin: 8px 0 4px;"><%= @bed.name %></h2>
<p style="color: var(--text-secondary); font-size: 12px; margin-bottom: 12px;">
  <%= (@bed.width || 100).round %>x<%= (@bed.length || 100).round %>cm
  · <%= @bed.grid_cols %>x<%= @bed.grid_rows %> grid
  · <%= @plants.count %> plants
</p>

<%= erb :"shared/_bed_svg", locals: { bed: @bed, plants: @plants, max_height: "400px", interactive: false } %>

<div style="margin-top: 12px;">
  <a href="/beds" style="color: var(--green-900); font-size: 13px;">← Back to beds</a>
</div>

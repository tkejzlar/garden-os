<!-- Back Link -->
<a href="/beds" class="text-sm hover:underline mb-5 inline-block" style="color: var(--green-900);">
  &larr; Garden Map
</a>

<!-- Page Header -->
<div class="mb-5">
  <h1 class="text-2xl font-bold" style="color: var(--text-primary); letter-spacing: -0.5px;">
    <%= @bed.name %>
  </h1>
  <p class="text-sm mt-1 capitalize" style="color: var(--text-secondary);">
    <%= @bed.bed_type %><% if @bed.orientation %> &mdash; <%= @bed.orientation %><% end %>
  </p>
</div>

<!-- Rows -->
<% @rows.each do |row| %>
  <div class="mb-5">
    <p class="mb-2" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; color: var(--gray-500);">
      <%= row.name %>
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      <% (@slots_by_row[row.id] || []).each do |slot| %>
        <% plant = @plants_by_slot[slot.id]&.first %>
        <div style="background: white; border-radius: var(--card-radius); padding: 12px 14px; box-shadow: var(--card-shadow);">
          <p class="mb-1" style="font-size: 10px; color: var(--gray-400);">
            <%= slot.name %>
          </p>
          <% if plant %>
            <a href="/plants/<%= plant.id %>" class="block">
              <p class="font-semibold text-sm" style="color: var(--text-primary);">
                <%= plant.variety_name %>
              </p>
              <p class="text-xs capitalize mt-0.5" style="color: var(--green-900);">
                <%= plant.lifecycle_stage.tr('_', ' ') %>
              </p>
            </a>
          <% else %>
            <p class="text-sm" style="color: var(--gray-400);">Empty</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

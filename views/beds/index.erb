<%
  crop_colors = {
    "tomato"   => { bg: "#fee2e2", border: "#fca5a5", text: "#991b1b" },
    "pepper"   => { bg: "#ffedd5", border: "#fdba74", text: "#9a3412" },
    "cucumber" => { bg: "#dcfce7", border: "#86efac", text: "#166534" },
    "herb"     => { bg: "#d1fae5", border: "#6ee7b7", text: "#065f46" },
    "flower"   => { bg: "#fce7f3", border: "#f9a8d4", text: "#9d174d" },
    "lettuce"  => { bg: "#fef9c3", border: "#fde047", text: "#713f12" },
    "squash"   => { bg: "#fef3c7", border: "#fcd34d", text: "#92400e" },
    "brassica" => { bg: "#ede9fe", border: "#c4b5fd", text: "#4c1d95" },
  }
  empty_colors = { bg: "#f9fafb", border: "#e5e7eb", text: "#9ca3af" }

  def crop_cell_style(plant, crop_colors, empty_colors)
    if plant
      c = crop_colors[plant.crop_type] || { bg: "#f3f4f6", border: "#d1d5db", text: "#374151" }
    else
      c = empty_colors
    end
    "background: #{c[:bg]}; border: 1px solid #{c[:border]}; color: #{c[:text]};"
  end
%>

<!-- Page Header -->
<div class="mb-5">
  <h1 class="text-2xl font-bold" style="color: var(--text-primary); letter-spacing: -0.5px;">Garden Map</h1>
</div>

<!-- Crop Color Legend -->
<div class="flex flex-wrap gap-1.5 mb-5">
  <% crop_colors.each do |crop, c| %>
    <span class="px-2 py-0.5 rounded-full text-xs font-medium"
          style="background: <%= c[:bg] %>; color: <%= c[:text] %>; border: 1px solid <%= c[:border] %>;">
      <%= crop.capitalize %>
    </span>
  <% end %>
  <span class="px-2 py-0.5 rounded-full text-xs font-medium"
        style="background: <%= empty_colors[:bg] %>; color: <%= empty_colors[:text] %>; border: 1px solid <%= empty_colors[:border] %>;">
    Empty
  </span>
</div>

<!-- Bed Cards Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
  <% @bed_data.each do |bd| %>
    <% bed = bd[:bed] %>
    <a href="/beds/<%= bed.id %>" class="block transition hover:opacity-90"
       style="background: white; border-radius: var(--card-radius); padding: 14px 16px; box-shadow: var(--card-shadow);">
      <h2 class="font-semibold mb-3" style="color: var(--text-primary);">
        <%= bed.name %>
      </h2>
      <% plants = bed.plants.exclude(lifecycle_stage: "done").all rescue [] %>
      <% if plants.any? %>
        <div class="flex gap-1 flex-wrap">
          <% plants.each do |plant| %>
            <% c = crop_colors[plant.crop_type] || { bg: "#f3f4f6", border: "#d1d5db", text: "#374151" } %>
            <div class="w-7 h-7 rounded text-center text-xs flex items-center justify-center font-medium"
                 style="background: <%= c[:bg] %>; border: 1px solid <%= c[:border] %>; color: <%= c[:text] %>;"
                 title="<%= plant.variety_name %> (<%= plant.lifecycle_stage.tr('_', ' ') %>)">
              <%= plant.variety_name[0..1] %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-xs" style="color: var(--gray-400);">Empty</p>
      <% end %>
    </a>
  <% end %>
</div>

<!-- Arches Section -->
<% unless @arches.empty? %>
  <p class="mb-3" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; color: var(--gray-500);">
    Arches
  </p>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <% @arches.each do |arch| %>
      <div style="background: white; border-radius: var(--card-radius); padding: 12px 14px; box-shadow: var(--card-shadow);">
        <p class="font-semibold text-sm mb-1" style="color: var(--text-primary);">
          <%= arch.name %>
        </p>
        <p class="text-xs mb-2" style="color: var(--text-secondary);">
          <%= arch.between_beds %>
        </p>
        <p class="text-xs" style="color: var(--text-body);">
          <span style="color: var(--gray-500);">Spring:</span>
          <%= arch.spring_crop || "—" %>
        </p>
        <p class="text-xs" style="color: var(--text-body);">
          <span style="color: var(--gray-500);">Summer:</span>
          <%= arch.summer_crop || "—" %>
        </p>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Indoor Stations Section -->
<% unless @indoor_stations.empty? %>
  <p class="mb-3" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; color: var(--gray-500);">
    Indoor
  </p>
  <div class="grid grid-cols-2 gap-3">
    <% @indoor_stations.each do |station| %>
      <% plants = Plant.where(indoor_station_id: station.id).exclude(lifecycle_stage: "done").all %>
      <div style="background: white; border-radius: var(--card-radius); padding: 12px 14px; box-shadow: var(--card-shadow);">
        <p class="font-semibold text-sm mb-1" style="color: var(--text-primary);">
          <%= station.name %>
        </p>
        <p class="text-xs" style="color: var(--text-secondary);">
          <%= plants.count %> <%= plants.count == 1 ? "plant" : "plants" %>
        </p>
      </div>
    <% end %>
  </div>
<% end %>

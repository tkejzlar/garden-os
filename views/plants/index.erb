<div x-data="{ selectMode: false, selected: [], batchStage: '' }">

  <!-- Page Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--text-primary)">Plants</h1>
    <button @click="selectMode = !selectMode; if (!selectMode) selected = []"
            class="text-sm px-3 py-1.5 rounded-lg font-medium transition"
            :style="selectMode ? 'background: var(--green-900); color: white;' : 'background: white; color: var(--green-900); box-shadow: var(--card-shadow);'"
            x-text="selectMode ? 'Cancel' : 'Select'">
    </button>
  </div>

  <!-- Batch Bar (fixed above tab bar) -->
  <div x-show="selectMode && selected.length > 0"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 translate-y-4"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 translate-y-4"
       style="position: fixed; bottom: 64px; left: 0; right: 0; z-index: 40; padding: 0 16px 8px;"
       x-cloak>
    <form method="post" action="/plants/batch_advance"
          class="flex items-center gap-3 rounded-xl px-4 py-3"
          style="background: white; box-shadow: 0 -2px 16px rgba(0,0,0,0.12);">
      <input type="hidden" name="plant_ids" :value="selected.join(',')">
      <span class="text-sm font-medium" style="color: var(--text-primary)">
        <span x-text="selected.length"></span> selected —
      </span>
      <span class="text-sm" style="color: var(--text-secondary)">Advance to:</span>
      <select name="stage" x-model="batchStage"
              class="flex-1 text-sm rounded-lg px-2 py-1.5 border"
              style="border-color: #e5e7eb; color: var(--text-primary);">
        <option value="">Choose stage...</option>
        <% Plant::LIFECYCLE_STAGES.each do |stage| %>
          <option value="<%= stage %>"><%= stage.tr('_', ' ').capitalize %></option>
        <% end %>
      </select>
      <button type="submit" :disabled="!batchStage"
              class="text-sm px-4 py-1.5 rounded-lg font-semibold text-white transition disabled:opacity-40"
              style="background: var(--green-900);">
        Apply
      </button>
    </form>
  </div>

  <!-- Plants Grouped by Crop Type -->
  <% if @plants.empty? %>
    <div class="text-center py-12" style="color: var(--text-secondary)">
      <p class="text-base">No plants yet.</p>
    </div>
  <% else %>
    <% @plants.group_by(&:crop_type).sort.each do |crop, plants| %>
      <!-- Section Heading -->
      <p class="mb-2 mt-5 first:mt-0"
         style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; color: var(--gray-500);">
        <%= crop.capitalize %>
      </p>

      <div class="space-y-2 mb-2">
        <% plants.each do |plant| %>
          <%
            stage_idx = Plant::LIFECYCLE_STAGES.index(plant.lifecycle_stage).to_i
            next_stages = Plant::LIFECYCLE_STAGES.drop(stage_idx + 1).first(2)
            done = plant.lifecycle_stage == "done"
            stage_color = done ? "var(--gray-400)" : "var(--green-900)"
          %>
          <div class="flex items-center gap-3 px-4 py-3"
               style="background: white; border-radius: var(--card-radius); box-shadow: var(--card-shadow);">

            <!-- Checkbox (select mode only) -->
            <div x-show="selectMode" style="flex-shrink: 0;">
              <input type="checkbox"
                     :value="<%= plant.id %>"
                     @change="$event.target.checked ? selected.push(<%= plant.id %>) : selected = selected.filter(x => x !== <%= plant.id %>)"
                     class="w-5 h-5 rounded accent-green-700">
            </div>

            <!-- Plant Info -->
            <a href="/plants/<%= plant.id %>" class="flex-1 min-w-0">
              <p class="font-semibold truncate" style="color: var(--text-primary);">
                <%= plant.variety_name %>
              </p>
              <p class="text-sm capitalize" style="color: <%= stage_color %>;">
                <%= plant.lifecycle_stage.tr('_', ' ') %>
              </p>
            </a>

            <!-- Quick-Advance Buttons -->
            <div x-show="!selectMode" class="flex gap-1.5" style="flex-shrink: 0;">
              <% next_stages.each do |ns| %>
                <form method="post" action="/plants/<%= plant.id %>/advance" class="inline">
                  <input type="hidden" name="stage" value="<%= ns %>">
                  <button type="submit"
                          class="text-xs px-2 py-1 rounded-lg font-medium transition hover:bg-gray-200"
                          style="background: #f3f4f6; color: var(--text-primary);">
                    <%= ns.tr('_', ' ') %>
                  </button>
                </form>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

</div>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GardenOS</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#365314">
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/lucide@0.460.0"></script>
  <style>
    :root {
      --green-900: #365314;
      --green-50: #f0fdf4;
      --yellow-50: #fefce8;
      --amber-50: #fffbeb;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --text-primary: #1a2e05;
      --text-secondary: #6b7280;
      --text-body: #1f2937;
      --card-bg: #ffffff;
      --card-shadow: 0 1px 3px rgba(0,0,0,0.06);
      --card-radius: 12px;
      --alert-amber-bg: #fef3c7;
      --alert-amber-border: #d97706;
      --alert-red-bg: #fef2f2;
      --alert-red-text: #991b1b;
      --success: #86efac;
      --warning: #ea580c;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      color: var(--text-body);
      min-height: 100vh;
      background: linear-gradient(180deg, #f0fdf4 0%, #fefce8 40%, #fffbeb 100%);
      background-attachment: fixed;
      margin: 0;
    }

    main { padding-bottom: 80px; }

    .tab-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 50;
      display: flex;
      background: #fff;
      border-top: 1px solid rgba(0,0,0,0.08);
      box-shadow: 0 -1px 8px rgba(0,0,0,0.06);
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    .tab-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      padding: 10px 4px 8px;
      text-decoration: none;
      color: var(--gray-400);
      font-size: 11px;
      -webkit-tap-highlight-color: transparent;
      transition: color 0.15s ease;
    }

    .tab-item.active {
      color: var(--green-900);
      font-weight: 600;
    }
  </style>
</head>
<body>
  <main class="max-w-4xl mx-auto px-4 py-6">
    <%= yield %>
  </main>

  <nav class="tab-bar">
    <%
      p = request.path_info
      home_active       = (p == "/")
      plants_active     = p.start_with?("/plants")
      beds_active       = p.start_with?("/beds")
      succession_active = p.start_with?("/succession")
    %>
    <a href="/" class="tab-item<%= ' active' if home_active %>">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Home
    </a>
    <a href="/plants" class="tab-item<%= ' active' if plants_active %>">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
      </svg>
      Plants
    </a>
    <a href="/beds" class="tab-item<%= ' active' if beds_active %>">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      Beds
    </a>
    <a href="/succession" class="tab-item<%= ' active' if succession_active %>">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
      </svg>
      Succession
    </a>
  </nav>

  <script>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js");
    }
  </script>
</body>
</html>
